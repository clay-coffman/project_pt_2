services:
  minecraft:
    image: itzg/minecraft-server
    container_name: minecraft
    ports:
      - "25565:25565"
    environment:
      EULA: "TRUE"
      TYPE: "VANILLA"
      VERSION: "{{ minecraft_version }}"
      MEMORY: "2G"
      MOTD: "CS 312 Minecraft Server"
      MAX_PLAYERS: "10"
      VIEW_DISTANCE: "10"
      ONLINE_MODE: "TRUE"
      ENABLE_RCON: "TRUE"
      RCON_PASSWORD: "{{ rcon_password }}"
      STOP_DURATION: "60"
    volumes:
      - /opt/minecraft/data:/data
    restart: unless-stopped
    # Give the container time to run "stop" and save the world before it's
    # killed. Docker's default is 10s, which isn't enough.
    stop_grace_period: 90s
